---
import { USE_CASES } from '../consts';
---

<section id="use-cases" class="max-w-screen-xl mx-auto px-6 pb-20">
  <div class="text-center mb-12">
    <div class="inline-block px-4 py-1 text-xs font-semibold tracking-[2px] text-emerald-400 bg-emerald-400/10 rounded-2xl mb-4">BUILT FOR VISIONARIES</div>
    <h2 class="section-header tracking-tighter">Perfect for premium<br>crypto &amp; Web3 projects</h2>
    <p class="mt-3 max-w-md mx-auto text-lg text-zinc-400">This name positions your project as a rare and desirable digital jewel in a crowded market.</p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {USE_CASES.map((useCase) => (
      <div class="premium-card group bg-zinc-900 border border-zinc-700 hover:border-emerald-400/40 rounded-3xl p-7 flex flex-col">
        <div class="use-case-icon w-11 h-11 rounded-2xl bg-gradient-to-br from-emerald-400/10 to-transparent flex items-center justify-center mb-5 text-emerald-400">
          <i class={`fa-solid ${useCase.icon} text-2xl`}></i>
        </div>
        <h4 class="font-semibold text-xl tracking-tight mb-2">{useCase.title}</h4>
        <p class="text-zinc-400 flex-1">{useCase.description}</p>
      </div>
    ))}
  </div>
</section>
