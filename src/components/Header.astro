---
import { SITE, NAV_LINKS } from '../consts';
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-zinc-800">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex items-center gap-x-3">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-emerald-400 to-emerald-500 flex items-center justify-center shadow-inner">
          <i class="fa-solid fa-gem text-zinc-950 text-2xl"></i>
        </div>
        <div>
          <span class="font-semibold text-2xl tracking-tighter">Joyacrypto</span>
          <span class="text-xs text-zinc-500 font-mono tracking-[3px] block -mt-1">.COM</span>
        </div>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center gap-x-8 text-sm">
        {NAV_LINKS.map((link) => (
          <a href={link.href} class="hover:text-emerald-400 transition-colors">{link.label}</a>
        ))}
      </div>

      <div class="flex items-center gap-x-3">
        <a href="#contact"
           class="hidden sm:inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold rounded-2xl border border-zinc-700 hover:bg-zinc-900 transition-all active:scale-[0.985]">
          Inquire Now
        </a>
        <a href="#contact"
           class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-semibold rounded-2xl bg-emerald-400 hover:bg-emerald-300 text-zinc-950 transition-all active:scale-[0.985] shadow-lg shadow-emerald-400/20">
          <span class="font-semibold">Acquire Domain</span>
        </a>
      </div>
    </div>
  </div>
</nav>
